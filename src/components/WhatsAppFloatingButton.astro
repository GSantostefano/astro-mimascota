---
import { brandFull } from '../config/site';
import { buildWhatsAppLink } from '../lib/whatsapp';

const href = buildWhatsAppLink(
  `Hola ${brandFull}, quiero consultar por un aviso de mascota perdida o encontrada.`,
);
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full bg-brand-teal px-4 py-3 text-sm font-semibold text-white no-underline shadow-lg transition hover:bg-brand-teal-dark"
  aria-label="Contactar por WhatsApp"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5" aria-hidden="true">
    <path
      d="M12.04 2C6.58 2 2.15 6.4 2.15 11.83c0 1.99.58 3.85 1.59 5.44L2 22l4.9-1.63a9.9 9.9 0 0 0 5.14 1.42h.01c5.46 0 9.89-4.4 9.89-9.83C21.94 6.4 17.5 2 12.04 2Zm5.76 13.95c-.24.67-1.4 1.23-1.93 1.31-.5.07-1.13.1-1.82-.11-.42-.13-.96-.31-1.66-.61-2.92-1.26-4.82-4.2-4.97-4.4-.14-.2-1.2-1.6-1.2-3.05 0-1.45.76-2.16 1.03-2.45.27-.29.59-.36.79-.36h.57c.18 0 .42-.07.66.5.24.58.82 2 .89 2.15.07.14.12.32.02.51-.1.2-.15.32-.3.5-.14.17-.3.38-.43.51-.14.14-.29.29-.12.56.16.28.73 1.2 1.56 1.94 1.07.96 1.97 1.26 2.25 1.4.28.14.44.12.6-.07.17-.2.7-.81.88-1.09.19-.28.37-.23.62-.14.26.1 1.63.77 1.91.91.28.14.47.21.54.32.07.12.07.67-.17 1.34Z"
    ></path>
  </svg>
  WhatsApp
</a>
