---
import { SITE, brandFull } from '../config/site';
import { buildWhatsAppLink } from '../lib/whatsapp';
import BrandLogo from './BrandLogo.astro';
import SocialLinks from './SocialLinks.astro';

const wspLink = buildWhatsAppLink(
  `Hola ${brandFull}, quiero consultar por un aviso de mascota en ${SITE.city}.`,
);
---

<footer class="mt-16 border-t border-brand-line bg-brand-sand">
  <div class="mx-auto max-w-6xl px-5 py-10">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <BrandLogo size="md" />
        <p class="mt-2 text-sm text-brand-muted">{SITE.tagline}</p>
      </div>
      <div>
        <p class="text-sm font-semibold text-brand-ink">Enlaces</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/mascotas" class="text-brand-muted no-underline hover:text-brand-ink">Mascotas</a></li>
          <li><a href="/publicar" class="text-brand-muted no-underline hover:text-brand-ink">Publicar aviso</a></li>
          <li><a href="/como-funciona" class="text-brand-muted no-underline hover:text-brand-ink">Cómo funciona</a></li>
          <li><a href="/contacto" class="text-brand-muted no-underline hover:text-brand-ink">Contacto</a></li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-brand-ink">Contacto</p>
        <p class="mt-3 text-sm text-brand-muted">
          <a href={`tel:+54${SITE.phone}`} class="text-brand-ink no-underline hover:underline">
            {SITE.phoneDisplay}
          </a>
        </p>
        <a
          href={wspLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-2 inline-block text-sm font-semibold text-brand-teal no-underline hover:underline"
        >
          WhatsApp
        </a>
        <p class="mt-4 text-sm font-semibold text-brand-ink">Redes</p>
        <SocialLinks class="mt-2" />
      </div>
    </div>
    <p class="mt-8 border-t border-brand-line pt-6 text-center text-xs text-brand-muted">
      © {new Date().getFullYear()} {brandFull}. Todos los derechos reservados.
    </p>
    <p class="mt-3 text-center text-[11px] leading-relaxed text-brand-muted/80">
      {SITE.legalDisclaimer}
    </p>
  </div>
</footer>
