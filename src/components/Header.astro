---
import { SITE } from '../config/site';
import BrandLogo from './BrandLogo.astro';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/mascotas', label: 'Mascotas' },
  { href: '/publicar', label: 'Publicar' },
  { href: '/como-funciona', label: 'Cómo funciona' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contacto', label: 'Contacto' },
];
---

<div class="border-b border-brand-line bg-brand-sand">
  <div class="mx-auto max-w-6xl px-5 py-2 text-center text-xs text-brand-muted md:text-left">
    <span class="font-medium text-brand-teal">{SITE.city}, {SITE.province}</span>
    <span class="mx-2 hidden text-brand-line md:inline">|</span>
    <span class="hidden md:inline">Avisos de mascotas perdidas y encontradas</span>
  </div>
</div>

<header class="sticky top-0 z-30 border-b border-brand-line bg-brand-cream/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-5 py-4">
    <BrandLogo />
    <nav aria-label="Navegación principal" class="flex flex-wrap gap-3 text-sm font-medium md:gap-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-brand-muted no-underline transition hover:text-brand-ink"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
