# Backend
BACK_PORT=3010
NODE_ENV=development
DEBUG_ROUTES=0

# ----------------------------
# MySQL (Workbench)
# ----------------------------
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3307
DB_NAME=mimascota
DB_USER=root
DB_PASSWORD=change_me
DB_LOG=0
DB_SYNC=1

# ----------------------------
# SQLite (alternativa local)
# ----------------------------
# DB_DIALECT=sqlite
# DB_PATH=./database.sqlite

# ----------------------------
# PostgreSQL (alternativa)
# ----------------------------
# DB_DIALECT=postgres
# DB_USER=postgres
# DB_PASSWORD=change_me
# DB_HOST=localhost
# DB_NAME=mimascota
# DB_PORT=5432
# DB_SSL=0

# JWT
JWT_SECRET=change_me_mimascota_jwt_secret
JWT_EXPIRES_IN=7d

# CORS — orígenes del front Astro
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# Rate limit
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=240
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX_REQUESTS=30
